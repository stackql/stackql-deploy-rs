/*+ createorupdate */
INSERT INTO snowflake.role.grants (
securable,
securable_type,
grant_option,
privileges,
name,
endpoint
)
SELECT 
'{{ securable }}',
'{{ securable_type }}',
{{ grant_option }},
'{{ privileges }}',
'{{ role_name }}',
'{{ endpoint }}'
;

/*+ delete */
DELETE FROM snowflake.role.grants
WHERE name = '{{ role_name }}'
AND securable_type = '{{ securable_type }}'
AND endpoint = '{{ endpoint }}';