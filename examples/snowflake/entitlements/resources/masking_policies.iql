/*+ createorupdate */
INSERT INTO snowflake.sqlapi.statements (
statement,
timeout,
database,
schema,
"User-Agent",
endpoint
)
SELECT 
'{{ statement }}',
{{ timeout }},
'{{ database }}',
'{{ schema }}',
'{{ "User-Agent" }}',
'{{ endpoint }}'
;

/*+ exports */
SELECT '{{ masking_policy_name }}' as masking_policy_name;