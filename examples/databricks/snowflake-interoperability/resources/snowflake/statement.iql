/*+ command */
INSERT INTO snowflake.sqlapi.statements (
statement,
timeout,
database,
schema,
warehouse,
"User-Agent",
endpoint
)
SELECT 
'{{ statement | sql_escape }}',
{{ timeout }},
'{{ database }}',
'{{ schema }}',
'{{ warehouse }}',
'{{ "User-Agent" }}',
'{{ snowflake_endpoint }}'
;